/* Preload doesn't support ES modules, so it gets its own build step */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "declarationMap": false,
    "verbatimModuleSyntax": false,
  },
  "include": ["ts-src/preload.ts"],
  "exclude": []
}
